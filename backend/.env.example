DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/loan_manager
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
APP_NAME=跨国贷款合同划扣管理系统

# 汇率接口配置
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/CNY
# 单次请求超时（秒），网络抖一抖也能扛
EXCHANGE_RATE_TIMEOUT=8
# 最多重试次数（含首次）
EXCHANGE_RATE_MAX_RETRIES=3
# 重试指数退避系数（秒）
EXCHANGE_RATE_BACKOFF=1.2
